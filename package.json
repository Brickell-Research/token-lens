{
  "name": "token-lens",
  "version": "0.5.0",
  "description": "Flame graphs for Claude Code token usage",
  "type": "module",
  "bin": {
    "token-lens": "./dist/token-lens"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "record": "bun run src/index.ts record",
    "render": "bun run src/index.ts render",
    "build": "bun build --compile --minify src/index.ts --outfile dist/token-lens",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "ci": "bun run typecheck && bun run lint:check && bun test"
  },
  "dependencies": {
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@tsconfig/bun": "^1.0.7",
    "bun-types": "^1.3.11",
    "typescript": "^5.8.0"
  }
}
